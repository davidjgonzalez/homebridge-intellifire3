{
  "displayName": "Homebridge Intellifire (v3)",
  "name": "homebridge-intellifire3",
  "version": "1.0.0",
  "description": "Homebridge plugin for Intellifire (Hearth & Home) fireplaces — exposes power, pilot, flame height, blower, ambient light, and thermostat controls in the Apple Home app.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidjgonzalez/homebridge-intellifire3.git"
  },
  "bugs": {
    "url": "https://github.com/davidjgonzalez/homebridge-intellifire3/issues"
  },
  "engines": {
    "node": "^18.17.0 || ^22.12.0",
    "homebridge": "^1.6.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src/**.ts --max-warnings=0",
    "watch": "npm run build && npm link && nodemon",
    "build": "rimraf ./dist && tsc",
    "prepublishOnly": "npm run lint && npm run build",
    "dev": "npm run build && docker-compose up --build"
  },
  "keywords": [
    "homebridge-plugin"
  ],
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^1.0.0",
    "node-fetch-cookies": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^18.16.20",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.45.0",
    "homebridge": "^1.8.0",
    "nodemon": "^2.0.22",
    "rimraf": "^3.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  }
}
